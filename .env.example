# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Connection
DATABASE_URL=postgresql+psycopg2://kyc:kyc@localhost:5432/kyc_auditor

# Admin Login (seeded via `python scripts/seed_admin.py` — ADMIN accounts are never self-registerable)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=Platform Administrator

# AI Orchestration Keys (At least one is required for agent execution)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Adverse Media Monitoring
GOOGLE_NEWS_RSS=https://news.google.com/rss/search
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
